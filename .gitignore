# macOS
.DS_Store

# Xcode / SwiftPM build output
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# XcodeGen workflow: project.pbxproj IS committed (regenerated from project.yml
# via `xcodegen generate`; the committed copy lets Xcode open without running
# xcodegen first). User-specific xcodeproj data is still ignored below.
# xcshareddata/swiftpm/Package.resolved IS committed for reproducible package
# resolution across clones.
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# Editor / IDE backups and temp files
*.bak
*.bak[0-9]
*.bak[0-9][0-9]
*.orig
*.swp
*.swo
*~
# Swift file variants left by dev tooling or manual editing
*.swift.disabled
*.swift.bak
*.swift.bak[0-9]

# Logs and profile data
*.log
*.profraw
*.xccovreport
*.xcresult

# Local environment / secrets
.env
*.local
