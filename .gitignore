# macOS
.DS_Store

# Xcode / SwiftPM build output
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# XcodeGen workflow:
#   - project.pbxproj IS committed (regenerated from project.yml via
#     `xcodegen generate`; the committed copy lets Xcode open without running
#     xcodegen first).
#   - xcshareddata/ IS committed (Package.resolved + .xcscheme files give
#     reproducible package pinning and a default scheme on fresh clones).
#   - xcuserdata/ is ALWAYS ignored (per-developer state).
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Python bytecode cache (from scripts/validate-project-spec.py)
__pycache__/
*.pyc

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# Editor / IDE backups and temp files
*.bak
*.bak[0-9]
*.bak[0-9][0-9]
*.orig
*.swp
*.swo
*~
# Swift file variants left by dev tooling or manual editing
*.swift.disabled
*.swift.bak
*.swift.bak[0-9]

# Logs and profile data
*.log
*.profraw
*.xccovreport
*.xcresult

# Local environment / secrets
.env
*.local
